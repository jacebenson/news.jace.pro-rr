<% content_for :title, "#{@session.code} - Admin" %>

<div class="mb-6">
  <%= link_to "← Back to Sessions", admin_knowledge_sessions_path, class: "text-blue-600 hover:text-blue-800" %>
</div>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <div class="flex justify-between items-start mb-4">
    <div>
      <span class="inline-block rounded bg-slate-100 px-2 py-1 text-sm font-mono text-slate-700 mb-2">
        <%= @session.code %>
      </span>
      <h1 class="text-2xl font-bold text-gray-900"><%= @session.title %></h1>
      <p class="text-gray-500 mt-1"><%= @session.event_name %></p>
    </div>
    <div class="flex gap-2">
      <% if @session.knowledge_url.present? %>
        <%= link_to "View on Knowledge", @session.knowledge_url, target: "_blank", rel: "noopener",
            class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 text-sm" %>
      <% end %>
      <%= link_to "Edit", edit_admin_knowledge_session_path(@session),
          class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm" %>
    </div>
  </div>

  <% if @session.abstract.present? %>
    <div class="mt-4 text-gray-700 prose max-w-none">
      <%= simple_format(@session.abstract) %>
    </div>
  <% end %>

  <div class="mt-4 text-sm text-gray-500">
    <p>Session ID: <code class="bg-gray-100 px-1 rounded"><%= @session.session_id %></code></p>
    <% if @session.recording_url.present? %>
      <p class="mt-1">Recording: <%= link_to @session.recording_url, @session.recording_url, target: "_blank", class: "text-blue-600 hover:underline" %></p>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="px-6 py-4 border-b flex justify-between items-center">
    <h2 class="text-lg font-semibold text-gray-900">Speakers (<%= @speakers.count %>)</h2>
  </div>

  <% if @speakers.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Speaker</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Company</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @speakers.each do |speaker| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center gap-3">
                <% if speaker.image_url.present? %>
                  <img src="<%= speaker.image_url %>" alt="" class="h-10 w-10 rounded-full object-cover">
                <% else %>
                  <div class="h-10 w-10 rounded-full bg-slate-200 flex items-center justify-center">
                    <span class="text-slate-500 text-sm font-medium"><%= speaker.name.first.upcase %></span>
                  </div>
                <% end %>
                <div>
                  <%= link_to speaker.name, admin_participant_path(speaker), class: "font-medium text-gray-900 hover:text-blue-600" %>
                  <p class="text-xs text-gray-400">ID: <%= speaker.id %></p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= speaker.company_name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= speaker.title %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <%= button_to "Remove", remove_speaker_admin_knowledge_session_path(@session, participant_id: speaker.id),
                  method: :delete,
                  class: "text-red-600 hover:text-red-800 text-sm",
                  data: { turbo_confirm: "Remove #{speaker.name} from this session?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="p-6 text-gray-500">No speakers linked to this session.</p>
  <% end %>
</div>

<% if @session.participants.present? %>
  <div class="bg-white rounded-lg shadow p-6 mt-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Raw Participants Data (from API)</h2>
    <pre class="bg-gray-50 p-4 rounded text-xs overflow-auto"><%= JSON.pretty_generate(@session.participants_array) %></pre>
  </div>
<% end %>
