<% require 'csv' -%>
<%= CSV.generate do |csv|
  # Header row
  csv << ['Title', 'Code', 'Link', 'Description', 'Speakers', 'Speaker Companies', 'Day', 'Start', 'End', 'Location']

  @sessions.each do |session|
    # Get speaker information
    speakers = session.speakers.map(&:name).join(', ')
    speaker_companies = session.speakers.map(&:company_name).compact.reject(&:blank?).uniq.join(', ')

    # Get times array
    times = session.times_array

    if times.any?
      # Create a row for each time slot
      times.each do |time|
        # Parse and format day like "Mon May 5"
        day = ""
        if time['dateFormatted'].present?
          begin
            parsed_date = Date.parse(time['dateFormatted'].to_s)
            day = parsed_date.strftime("%a %b %-d")
          rescue
            day = time['dateFormatted'].to_s
          end
        elsif time['date'].present?
          begin
            parsed_date = Date.parse(time['date'].to_s)
            day = parsed_date.strftime("%a %b %-d")
          rescue
            day = time['date'].to_s
          end
        end

        # Extract start and end times
        start_time = time['startTimeFormatted'].to_s
        end_time = time['endTimeFormatted'].to_s

        location = time['room'].to_s

        csv << [
          session.title,
          session.code,
          session.knowledge_url || session.url,
          session.abstract,
          speakers,
          speaker_companies,
          day,
          start_time,
          end_time,
          location
        ]
      end
    else
      # No times - still output a row
      csv << [
        session.title,
        session.code,
        session.knowledge_url || session.url,
        session.abstract,
        speakers,
        speaker_companies,
        '',
        '',
        '',
        ''
      ]
    end
  end
end.html_safe -%>
