<%= turbo_stream.replace "session-list-button-#{@ksession.id}" do %>
  <% in_list = current_user.saved_sessions.exists?(@ksession.id) %>
  <%= button_to toggle_session_list_path(@ksession), method: :post,
      id: "session-list-button-#{@ksession.id}",
      class: "rounded p-1 #{in_list ? 'text-yellow-500 bg-yellow-50' : 'text-gray-400 hover:text-yellow-500 hover:bg-yellow-50'}",
      title: in_list ? "Remove from list" : "Save to list" do %>
    <svg class="h-5 w-5" fill="<%= in_list ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
    </svg>
  <% end %>
<% end %>

<%= turbo_stream.append "flash-messages" do %>
  <div class="fixed top-4 right-4 z-50 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded shadow-lg" data-controller="flash" data-flash-timeout-value="3000">
    <%= flash[:notice] %>
  </div>
<% end if flash[:notice] %>
