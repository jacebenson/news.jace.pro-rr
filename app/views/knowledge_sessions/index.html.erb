<% content_for :title, "#{@event_name} Sessions - News Jace Pro" %>

<div class="mt-4">
  <div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @event_name %></h1>
      <p class="text-gray-600">
        <%= @active_count %> active sessions<% if @stale_count > 0 %>, <span class="text-amber-600"><%= @stale_count %> cancelled</span><% end %>
      </p>
    </div>

    <div class="flex items-center gap-4">
      <% if logged_in? %>
        <% if @showing_list %>
          <%= link_to "Show All", send("#{@event}_path"), class: "text-blue-600 hover:underline" %>
        <% else %>
          <%= link_to "My List", send("#{@event}_list_path", list: "mine"), class: "text-blue-600 hover:underline" %>
        <% end %>
      <% end %>

      <%= form_with url: send("#{@event}_path"), method: :get, class: "flex gap-2", local: true do |f| %>
        <%# Preserve session_types when searching %>
        <% if @session_types.present? %>
          <% @session_types.each do |type| %>
            <%= hidden_field_tag "session_types[]", type %>
          <% end %>
        <% end %>
        <%= text_field_tag :search, @search, placeholder: "Search sessions...",
            class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border text-sm" %>
        <%= f.submit "Search", class: "rounded-md bg-blue-600 px-4 py-2 text-white text-sm hover:bg-blue-700 cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <%# Navigation tabs - Parties / All Sessions / Expo Map / Add Event %>
  <div class="mb-4 flex flex-wrap gap-2">
    <%= link_to "Parties", send("#{@event}_path", tags: "party"),
        class: "px-4 py-2 rounded-lg text-sm font-medium #{@tags == 'party' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <%= link_to "All Sessions", send("#{@event}_path"),
        class: "px-4 py-2 rounded-lg text-sm font-medium #{@tags.blank? && @company_filter.blank? && !@exclude_servicenow && @session_types.blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% if @event == "k26" %>
      <%= link_to "Expo Map ↗", "https://knowledge2026.expofp.com", target: "_blank", rel: "noopener",
          class: "px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200" %>
    <% end %>
    <% if admin? %>
      <%= link_to "+ Add Event", new_admin_knowledge_session_path(event: @event),
          class: "px-4 py-2 rounded-lg text-sm font-medium bg-green-600 text-white hover:bg-green-700" %>
    <% end %>
  </div>

  <%# Export Button %>
  <div class="mb-4 flex justify-end">
    <%= link_to send("#{@event}_export_path", params.permit(:search, :company, :exclude_servicenow, :venue, :room, :tags, :session_types, :speaker_filter).to_h, format: :csv),
        class: "inline-flex items-center gap-2 bg-green-600 text-white px-4 py-2 rounded text-sm hover:bg-green-700" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      Export CSV
    <% end %>
  </div>

  <%# Filters %>
  <%= form_with url: send("#{@event}_path"), method: :get, class: "mb-4 flex flex-wrap items-center gap-4 p-4 bg-gray-50 rounded-lg", local: true do |f| %>
    <%# Preserve search if present %>
    <% if @search.present? %>
      <%= hidden_field_tag :search, @search %>
    <% end %>

    <%# Preserve tags filter if present %>
    <% if @tags.present? %>
      <%= hidden_field_tag :tags, @tags %>
    <% end %>

    <div class="flex items-center gap-2">
      <label for="sort" class="text-sm font-medium text-gray-700">Sort:</label>
      <%= select_tag :sort,
          options_for_select([
            ["Active First", "default"],
            ["Last Updated", "updated"],
            ["A-Z", "alpha"],
            ["Start Time", "time"]
          ], @sort),
          class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border text-sm",
          onchange: "this.form.submit()" %>
    </div>

    <div class="flex items-center gap-2">
      <label for="venue" class="text-sm font-medium text-gray-700">Venue:</label>
      <%= select_tag :venue,
          options_for_select([["All Venues", ""]] + @all_venues.map { |v| [v, v] }, @venue_filter),
          class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border text-sm",
          onchange: "this.form.room.value = ''; this.form.submit()" %>
    </div>

    <div class="flex items-center gap-2">
      <label for="room" class="text-sm font-medium text-gray-700">Room:</label>
      <%= select_tag :room,
          options_for_select([["All Rooms", ""]] + @all_rooms.map { |r| [r, r] }, @room_filter),
          class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border text-sm",
          onchange: "this.form.submit()" %>
    </div>

    <div class="flex items-center gap-2">
      <label for="company" class="text-sm font-medium text-gray-700">Company:</label>
      <%= select_tag :company,
          options_for_select([["All Companies", ""]] + @all_companies.map { |c| [c, c] }, @company_filter),
          class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border text-sm",
          onchange: "this.form.submit()" %>
    </div>

    <label class="flex items-center gap-2 text-sm text-gray-700">
      <%= check_box_tag :exclude_servicenow, "1", @exclude_servicenow,
          class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500",
          onchange: "this.form.submit()" %>
      Exclude ServiceNow-only
    </label>

    <div class="flex items-center gap-2">
      <span class="text-sm font-medium text-gray-700">Types:</span>
      <% session_type_options = {
        "KEY" => "Keynotes",
        "SNU" => "Pre-conf",
        "CCL" => "Labs",
        "CCB" => "CreatorCon",
        "SES" => "Sessions",
        "SPN" => "Sponsored"
      } %>
      <% session_type_options.each do |code, label| %>
        <label class="flex items-center gap-1 text-xs text-gray-600 whitespace-nowrap cursor-pointer" title="Show <%= label %> sessions">
          <%= check_box_tag "session_types[]", code, @session_types&.include?(code),
              class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500",
              onchange: "this.form.submit()" %>
          <%= label %>
        </label>
      <% end %>
    </div>

    <div class="flex items-center gap-2">
      <label for="speaker_filter" class="text-sm font-medium text-gray-700">Speakers:</label>
      <%= select_tag :speaker_filter,
          options_for_select([
            ["All Speakers", ""],
            ["MVP Holders", "mvp"],
            ["SNAPP Card Holders", "snapp"],
            ["From Acquisitions", "acquisition"]
          ], @speaker_filter),
          class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 px-3 py-2 border text-sm",
          onchange: "this.form.submit()" %>
    </div>

    <span class="text-sm text-gray-500">
      <%= @active_count %> active<% if @stale_count > 0 %>, <span class="text-amber-600"><%= @stale_count %> cancelled</span><% end %>
    </span>
  <% end %>

  <% if @showing_list %>
    <div class="mb-4 p-4 bg-blue-50 rounded-lg">
      <% if @list_owner %>
        <p class="text-sm text-blue-800">
          <strong><%= @list_owner == current_user ? "Your" : "#{@list_owner.name || @list_owner.email}'s" %></strong> saved sessions for <%= @event_name %>
        </p>
        <% if @list_owner == current_user && @shareable_url.blank? %>
          <p class="text-xs text-blue-600 mt-1">
            Share this list: 
            <code class="bg-blue-100 px-1 py-0.5 rounded text-xs"><%= url_for(controller: "knowledge_sessions", action: "index", event: @event, list: current_user.id, only_path: false) %></code>
          </p>
        <% end %>
      <% else %>
        <p class="text-sm text-blue-800">
          <% if logged_in? %>
            You haven't saved any sessions yet.
          <% else %>
            <%= link_to "Log in", login_path, class: "underline" %> to save sessions to your list.
          <% end %>
        </p>
      <% end %>
    </div>
  <% end %>

  <% if @search.present? %>
    <div class="mb-4">
      <p class="text-sm text-gray-600">
        Showing results for "<%= @search %>"
        <%= link_to "Clear", send("#{@event}_path"), class: "text-blue-600 hover:underline ml-2" %>
      </p>
    </div>
  <% end %>

  <div class="space-y-4">
    <% @sessions.each do |ksession| %>
      <%= render "knowledge_sessions/card", ksession: ksession %>
    <% end %>
  </div>

  <% if @sessions.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No sessions found</p>
    </div>
  <% end %>

  <%# Pagination %>
  <% if @total_pages > 1 || @showing_all %>
    <% pagination_params = params.permit(:search, :company, :exclude_servicenow, :tags, :list, :venue, :room, :sort).to_h.symbolize_keys %>
    <div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t pt-4">
      <div class="text-sm text-gray-600">
        <% if @showing_all %>
          Showing all <%= @total_count %> sessions
        <% else %>
          Showing <%= (@page - 1) * @per_page + 1 %>–<%= [(@page * @per_page), @total_count].min %> of <%= @total_count %> sessions
        <% end %>
      </div>

      <div class="flex items-center gap-2">
        <% if @showing_all %>
          <%= link_to "Paginate", send("#{@event}_path", pagination_params.merge(page: 1)),
              class: "px-3 py-1 text-sm rounded border border-gray-300 hover:bg-gray-50" %>
        <% else %>
          <%# Previous page %>
          <% if @page > 1 %>
            <%= link_to "← Prev", send("#{@event}_path", pagination_params.merge(page: @page - 1)),
                class: "px-3 py-1 text-sm rounded border border-gray-300 hover:bg-gray-50" %>
          <% end %>

          <%# Page numbers %>
          <% pages_to_show = ([@page - 2, 1].max..[@page + 2, @total_pages].min) %>
          <% if pages_to_show.first > 1 %>
            <%= link_to "1", send("#{@event}_path", pagination_params.merge(page: 1)),
                class: "px-3 py-1 text-sm rounded border border-gray-300 hover:bg-gray-50" %>
            <% if pages_to_show.first > 2 %><span class="text-gray-400">…</span><% end %>
          <% end %>

          <% pages_to_show.each do |p| %>
            <% if p == @page %>
              <span class="px-3 py-1 text-sm rounded bg-blue-600 text-white"><%= p %></span>
            <% else %>
              <%= link_to p, send("#{@event}_path", pagination_params.merge(page: p)),
                  class: "px-3 py-1 text-sm rounded border border-gray-300 hover:bg-gray-50" %>
            <% end %>
          <% end %>

          <% if pages_to_show.last < @total_pages %>
            <% if pages_to_show.last < @total_pages - 1 %><span class="text-gray-400">…</span><% end %>
            <%= link_to @total_pages, send("#{@event}_path", pagination_params.merge(page: @total_pages)),
                class: "px-3 py-1 text-sm rounded border border-gray-300 hover:bg-gray-50" %>
          <% end %>

          <%# Next page %>
          <% if @page < @total_pages %>
            <%= link_to "Next →", send("#{@event}_path", pagination_params.merge(page: @page + 1)),
                class: "px-3 py-1 text-sm rounded border border-gray-300 hover:bg-gray-50" %>
          <% end %>

          <%# Show all link %>
          <%= link_to "Show All", send("#{@event}_path", pagination_params.merge(all: 1)),
              class: "ml-2 px-3 py-1 text-sm rounded border border-gray-300 hover:bg-gray-50" %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
